    "Double tap to cycle to the next TODO state. Long press for all states.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Doppeltippen, um zum nächsten TODO-Status zu wechseln. Für alle Status lange drücken."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca dos veces para pasar al siguiente estado TODO. Mantén pulsado para ver todos los estados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez deux fois pour passer à l'état TODO suivant. Appui long pour tous les états."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダブルタップで次のTODOステータスに切り替え。長押しですべてのステータスを表示。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque duas vezes para passar ao próximo estado TODO. Toque e segure para ver todos os estados."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轻点两下切换到下一个TODO状态。长按查看所有状态。"
          }
        }
      }
    },
    "Double tap to open folder.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Doppeltippen, um den Ordner zu öffnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca dos veces para abrir la carpeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez deux fois pour ouvrir le dossier."
          }
        },
        "ja": {
