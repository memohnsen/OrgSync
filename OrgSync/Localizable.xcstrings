    "Abandons the pending commit. Your file changes are kept as local changes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwirft den ausstehenden Commit. Deine Dateiänderungen bleiben als lokale Änderungen erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abandona el commit pendiente. Tus cambios de archivo se conservan como cambios locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Abandonne le commit en attente. Vos modifications de fichiers sont conservées comme modifications locales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保留中のコミットを破棄します。ファイルの変更はローカル変更として保持されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abandona o commit pendente. Suas alterações de arquivo são mantidas como alterações locais."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "放弃待处理的提交。你的文件更改会保留为本地更改。"
          }
        }
      }
    },
