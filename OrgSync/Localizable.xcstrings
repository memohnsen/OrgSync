    "All local and remote changes are reconciled.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle lokalen und Remote-Änderungen sind abgeglichen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los cambios locales y remotos están conciliados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les modifications locales et distantes sont synchronisées."
          }
        },
        "ja": {
