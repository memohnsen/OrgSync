    },
    "Quit and reopen OrgSync to use the new location.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beende OrgSync und öffne es erneut, um den neuen Speicherort zu verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra y vuelve a abrir OrgSync para usar la nueva ubicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quittez et rouvrez OrgSync pour utiliser le nouvel emplacement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい保存場所を使うには、OrgSyncを終了して再度開いてください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Feche e reabra o OrgSync para usar o novo local."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出并重新打开OrgSync以使用新位置。"
          }
        }
      }
    },
    "Red lines are only in your local file; green lines are only in the remote copy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rote Zeilen sind nur in deiner lokalen Datei, grüne Zeilen nur in der Remote-Kopie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las líneas rojas solo están en tu archivo local; las verdes, solo en la copia remota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les lignes rouges ne figurent que dans votre fichier local ; les vertes, uniquement dans la copie distante."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "赤い行はローカルファイルのみ、緑の行はリモートコピーのみに存在します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As linhas vermelhas estão apenas no seu arquivo local; as verdes, apenas na cópia remota."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "红色行仅存在于本地文件中；绿色行仅存在于远程副本中。"
          }
        }
      }
    },
