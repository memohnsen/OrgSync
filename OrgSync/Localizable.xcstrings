    "Choose the local or remote version for each conflicted file.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle für jede Konfliktdatei die lokale oder die Remote-Version."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la versión local o remota para cada archivo en conflicto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez la version locale ou distante pour chaque fichier en conflit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンフリクトした各ファイルについて、ローカル版またはリモート版を選択します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a versão local ou remota para cada arquivo em conflito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为每个冲突文件选择本地或远程版本。"
          }
        }
      }
    },
    "Choose the local or remote version for each conflicted file. Pushing is blocked until all conflicts are resolved.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle für jede Konfliktdatei die lokale oder die Remote-Version. Push ist blockiert, bis alle Konflikte gelöst sind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la versión local o remota para cada archivo en conflicto. No se puede hacer push hasta resolver todos los conflictos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez la version locale ou distante pour chaque fichier en conflit. Le push est bloqué tant que tous les conflits ne sont pas résolus."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンフリクトした各ファイルについて、ローカル版またはリモート版を選択します。すべてのコンフリクトを解決するまでプッシュはブロックされます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a versão local ou remota para cada arquivo em conflito. O push fica bloqueado até que todos os conflitos sejam resolvidos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为每个冲突文件选择本地或远程版本。在所有冲突解决之前无法推送。"
          }
        }
      }
    },
    "Choose today, upcoming, all scheduled, or unscheduled tasks.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle heutige, anstehende, alle geplanten oder ungeplante Aufgaben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige tareas de hoy, próximas, todas las programadas o sin programar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les tâches du jour, à venir, toutes les planifiées ou non planifiées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日、今後、すべての予定済み、または未予定のタスクを選択します。"
