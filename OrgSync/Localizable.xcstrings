    "Allow access to sync scheduled and deadline TODOs with a dedicated OrgSync list.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube den Zugriff, um geplante und fällige TODOs mit einer eigenen OrgSync-Liste zu synchronisieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite el acceso para sincronizar TODOs programados y con fecha límite con una lista dedicada de OrgSync."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez l'accès pour synchroniser les TODOs planifiés et à échéance avec une liste OrgSync dédiée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
