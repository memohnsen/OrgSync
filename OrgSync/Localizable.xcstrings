          "stringUnit": {
            "state": "translated",
            "value": "Balayez à droite pour terminer ou à gauche pour replanifier. Touchez deux fois pour ouvrir la note."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右スワイプで完了、左スワイプで再スケジュール。ダブルタップでメモを開きます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deslize para a direita para concluir ou para a esquerda para reagendar. Toque duas vezes para abrir a nota."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "右滑完成，左滑重新安排。轻点两下打开笔记。"
          }
        }
      }
    },
