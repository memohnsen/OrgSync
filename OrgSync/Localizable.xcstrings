    "Stop syncing with GitHub. You can keep the downloaded notes on this device or remove them.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beendet die Synchronisierung mit GitHub. Du kannst die heruntergeladenen Notizen auf diesem Gerät behalten oder entfernen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja de sincronizar con GitHub. Puedes conservar las notas descargadas en este dispositivo o eliminarlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrête la synchronisation avec GitHub. Vous pouvez conserver les notes téléchargées sur cet appareil ou les supprimer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHubとの同期を停止します。ダウンロード済みのメモはこのデバイスに保持するか削除できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para de sincronizar com o GitHub. Você pode manter as notas baixadas neste dispositivo ou removê-las."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止与GitHub同步。你可以将已下载的笔记保留在此设备上或删除。"
          }
        }
      }
    },
    "Stops syncing this repository. You can choose whether to keep local files.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beendet die Synchronisierung dieses Repositorys. Du kannst wählen, ob lokale Dateien behalten werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
