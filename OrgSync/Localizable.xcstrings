          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrête la synchronisation de ce dépôt. Vous pouvez choisir de conserver ou non les fichiers locaux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリポジトリの同期を停止します。ローカルファイルを保持するか選択できます。"
