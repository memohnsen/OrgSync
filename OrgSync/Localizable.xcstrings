        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择今天、即将到来、所有已计划或未计划的任务。"
          }
        }
      }
    },
    "Choose which version should remain, then sync again.": {
      "localizations": {
        "de": {
