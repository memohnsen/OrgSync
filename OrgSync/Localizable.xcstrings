    "Pull remote changes and push local edits.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Remote-Änderungen pullen und lokale Bearbeitungen pushen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz pull de los cambios remotos y push de las ediciones locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupérez les modifications distantes et poussez les modifications locales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモートの変更をプルし、ローカルの編集をプッシュします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça pull das alterações remotas e push das edições locais."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拉取远程更改并推送本地编辑。"
          }
        }
      }
    },
    "Pulls remote changes when the app becomes active.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pullt Remote-Änderungen, wenn die App aktiv wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace pull de los cambios remotos cuando la app se activa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupère les modifications distantes lorsque l'app devient active."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリがアクティブになったときにリモートの変更をプルします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faz pull das alterações remotas quando o app fica ativo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当应用变为活跃状态时拉取远程更改。"
          }
        }
