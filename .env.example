# Local-only credentials for the real GitHub integration test. Copy to .env and
# provide a disposable, repository-scoped token; .env is ignored by Git.
ORGSYNC_REVIEW_REPO_URL=https://github.com/OWNER/REPOSITORY
ORGSYNC_REVIEW_PAT=

# RevenueCat public SDK keys, injected into Info.plist at build time.
# Debug builds use the test key; Release builds (archives) use the live key.
REVENUECAT_API_KEY_TEST=
REVENUECAT_API_KEY_LIVE=
